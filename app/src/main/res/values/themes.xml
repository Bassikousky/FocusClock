<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.FocusLock" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorPrimaryVariant">@color/accent</item>
        <item name="colorOnPrimary">@color/bg_dark</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
    </style>

    <style name="Theme.FocusLock.Lock" parent="Theme.FocusLock">
        <item name="android:windowBackground">@color/lock_bg</item>
        <item name="android:statusBarColor">@color/lock_bg</item>
        <item name="android:navigationBarColor">@color/lock_bg</item>
        <item name="android:windowFullscreen">true</item>
    </style>
</resources>
